[Unit]
Description=Create writable Nix directory layout
Wants=systemd-sysusers.service
Requires=nix-prepare.service
After=nix-prepare.service systemd-sysusers.service
Before=nix-daemon.service nix-daemon.socket
ConditionPathIsMountPoint=/nix

[Service]
Type=oneshot
ExecStart=/usr/bin/systemd-tmpfiles --create /usr/lib/tmpfiles.d/nix.conf
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target

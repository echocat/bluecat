{
  "default": [
    {
      "type": "reject"
    }
  ],
  "transports": {
    "docker": {
      "ghcr.io/echocat/bluecat": [
        {
          "type": "sigstoreSigned",
          "keyPath": "/etc/pki/containers/bluecat-cosign.pub",
          "signedIdentity": {
            "type": "matchRepository"
          }
        }
      ],
      "": [
        {
          "type": "insecureAcceptAnything"
        }
      ]
    }
  }
}

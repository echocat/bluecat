#!/usr/bin/env bash
# =============================================================================
# image/setup/stage2  (runs in stage 2 / final)
# =============================================================================
# Runs the numbered setup steps under stage2.d as standalone scripts. They are
# executed, not sourced, so each step can choose its own shebang/interpreter.
# =============================================================================
set -euo pipefail

# shellcheck source=image/setup/common
source "$(dirname -- "${BASH_SOURCE[0]}")/common"

bluecat_run_steps "stage2" "$(dirname -- "${BASH_SOURCE[0]}")/stage2.d"

echo "==> Cleanup left over artifacts..."
dnf5 clean all
rm -f \
  /var/lib/dnf/system-repo.lock \
  /var/log/dnf5.log*
rm -rf \
  /var/lib/dnf/repos \
  /var/lib/iscsi \
  /var/lib/libvirt \
  /var/lib/rpm-state \
  /var/lib/swtpm-localca \
  /var/lib/xkb \
  /var/log/glusterfs \
  /var/log/libvirt \
  /var/log/swtpm

#!/usr/bin/env bash

retry() {
  local attempt max_attempts delay
  max_attempts=5
  delay=10

  for ((attempt = 1; attempt <= max_attempts; attempt++)); do
    if "$@"; then
      return 0
    fi

    if ((attempt == max_attempts)); then
      return 1
    fi

    echo "    attempt ${attempt}/${max_attempts} failed; retrying in ${delay}s..."
    sleep "${delay}"
    delay=$((delay * 2))
  done
}

bluecat_color_enabled() {
  [[ -z "${NO_COLOR:-}" && "${BLUECAT_COLOR:-1}" != "0" ]]
}

bluecat_color_for_text() {
  local text="$1"
  local checksum
  local -a colors=(31 32 33 34 35 36 91 92 93 94 95 96)

  checksum="$(printf '%s' "${text}" | cksum)"
  checksum="${checksum%% *}"
  printf '%s\n' "${colors[checksum % ${#colors[@]}]}"
}

bluecat_print_colored() {
  local text="$1"
  local color

  color="$(bluecat_color_for_text "${text}")"
  printf '\033[1;%sm%s\033[0m' "${color}" "${text}"
}

bluecat_print_headline() {
  local text="$1"
  local suffix="${2:-}"
  local color

  if bluecat_color_enabled; then
    color="$(bluecat_color_for_text "${text}")"
    printf '\033[1;%sm%s\033[0m%s\n' "${color}" "${text}" "${suffix}"
  else
    printf '%s%s\n' "${text}" "${suffix}"
  fi
}

format_duration() {
  local seconds="$1"

  printf '%02d:%02d:%02d' \
    $((seconds / 3600)) \
    $(((seconds % 3600) / 60)) \
    $((seconds % 60))
}

bluecat_run_steps() {
  local stage="$1"
  local steps_dir="$2"
  local step
  local step_name
  local -a steps
  local start
  local start_step

  if [[ ! -d "${steps_dir}" ]]; then
    echo "ERROR: steps directory not found: ${steps_dir}" >&2
    return 1
  fi

  shopt -s nullglob
  steps=("${steps_dir}"/*)
  shopt -u nullglob

  if (( ${#steps[@]} == 0 )); then
    echo "ERROR: no steps found in ${steps_dir}" >&2
    return 1
  fi

  start="$(date +%s)"
  bluecat_print_headline "[build:image:${stage}]"

  for step in "${steps[@]}"; do
    [[ -f "${step}" ]] || continue
    if [[ ! -x "${step}" ]]; then
      echo "ERROR: step is not executable: ${step}" >&2
      return 1
    fi

    step_name="$(basename "${step}")"
    start_step="$(date +%s)"
    bluecat_print_headline "[build:image:${stage}:${step_name}]"
    "${step}"
    echo "[build:image:${stage}:${step_name}] DONE! (took $(format_duration $(( $(date +%s) - start_step ))))"
  done

  echo "[build:image:${stage}] DONE! (took $(format_duration $(( $(date +%s) - start ))))"
}

bluecat_kernel_version() {
  local kver

  # The Kinoite image ships exactly one kernel package.
  kver="$(rpm -q kernel-core --queryformat '%{VERSION}-%{RELEASE}.%{ARCH}\n' | head -n1)"
  if [[ -z "${kver}" || "${kver}" == *"is not installed"* ]]; then
    echo "ERROR: could not determine kernel version." >&2
    return 1
  fi

  printf '%s\n' "${kver}"
}

bluecat_sign_module() {
  local kver="$1"
  local ko="$2"
  local cert_key="${3:-/tmp/certs/mok.key}"
  local cert_crt="${4:-/tmp/certs/mok.crt}"
  local sign_file="/usr/src/kernels/${kver}/scripts/sign-file"

  if [[ ! -x "${sign_file}" ]]; then
    echo "ERROR: sign-file not found at ${sign_file}" >&2
    return 1
  fi

  if [[ "${ko}" == *.xz ]]; then
    xz -d "${ko}"
    ko="${ko%.xz}"
  fi

  echo "    signing: ${ko}"
  "${sign_file}" sha256 "${cert_key}" "${cert_crt}" "${ko}"
}

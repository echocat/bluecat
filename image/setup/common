#!/usr/bin/env bash

retry() {
  local attempt max_attempts delay
  max_attempts=5
  delay=10

  for ((attempt = 1; attempt <= max_attempts; attempt++)); do
    if "$@"; then
      return 0
    fi

    if ((attempt == max_attempts)); then
      return 1
    fi

    echo "    attempt ${attempt}/${max_attempts} failed; retrying in ${delay}s..."
    sleep "${delay}"
    delay=$((delay * 2))
  done
}

bluecat_color_enabled() {
  [[ -z "${NO_COLOR:-}" && "${BLUECAT_COLOR:-1}" != "0" ]]
}

bluecat_step_start() {
  local step_name="$1"

  if bluecat_color_enabled; then
    printf '\033[1;36m==>\033[0m \033[36mRunning setup step:\033[0m \033[1m%s\033[0m\n' "${step_name}"
  else
    printf '==> Running setup step: %s\n' "${step_name}"
  fi
}

bluecat_step_done() {
  local step_name="$1"

  if bluecat_color_enabled; then
    printf '\033[1;32m==>\033[0m \033[32mSetup step done:\033[0m \033[1m%s\033[0m\n\n' "${step_name}"
  else
    printf '==> Setup step done: %s\n\n' "${step_name}"
  fi
}

bluecat_run_steps() {
  local steps_dir="$1"
  local done_message="$2"
  local step
  local step_name
  local -a steps

  if [[ ! -d "${steps_dir}" ]]; then
    echo "ERROR: setup steps directory not found: ${steps_dir}" >&2
    return 1
  fi

  shopt -s nullglob
  steps=("${steps_dir}"/*)
  shopt -u nullglob

  if (( ${#steps[@]} == 0 )); then
    echo "ERROR: no setup steps found in ${steps_dir}" >&2
    return 1
  fi

  for step in "${steps[@]}"; do
    [[ -f "${step}" ]] || continue
    if [[ ! -x "${step}" ]]; then
      echo "ERROR: setup step is not executable: ${step}" >&2
      return 1
    fi

    step_name="$(basename "${step}")"
    bluecat_step_start "${step_name}"
    "${step}"
    bluecat_step_done "${step_name}"
  done

  printf '==> %s\n\n' "${done_message}"
}

bluecat_kernel_version() {
  local kver

  # The Kinoite image ships exactly one kernel package.
  kver="$(rpm -q kernel-core --queryformat '%{VERSION}-%{RELEASE}.%{ARCH}\n' | head -n1)"
  if [[ -z "${kver}" || "${kver}" == *"is not installed"* ]]; then
    echo "ERROR: could not determine kernel version." >&2
    return 1
  fi

  printf '%s\n' "${kver}"
}

bluecat_sign_module() {
  local kver="$1"
  local ko="$2"
  local cert_key="${3:-/tmp/certs/mok.key}"
  local cert_crt="${4:-/tmp/certs/mok.crt}"
  local sign_file="/usr/src/kernels/${kver}/scripts/sign-file"

  if [[ ! -x "${sign_file}" ]]; then
    echo "ERROR: sign-file not found at ${sign_file}" >&2
    return 1
  fi

  if [[ "${ko}" == *.xz ]]; then
    xz -d "${ko}"
    ko="${ko%.xz}"
  fi

  echo "    signing: ${ko}"
  "${sign_file}" sha256 "${cert_key}" "${cert_crt}" "${ko}"
}

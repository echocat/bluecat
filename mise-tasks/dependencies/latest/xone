#!/usr/bin/env -S deno run --allow-net
//MISE description="Detects the current available release version of https://github.com/medusalix/xone"
//MISE hide=true
//MISE dir="{{config_root}}"

const response = await fetch(
  "https://api.github.com/repos/medusalix/xone/commits/master",
  { headers: { "accept": "application/vnd.github+json" } },
);

if (!response.ok) {
  console.error(`ERROR: GitHub returned ${response.status} for xone.`);
  Deno.exit(1);
}

const commit = await response.json() as { sha?: unknown };
if (typeof commit.sha !== "string" || commit.sha.length === 0) {
  console.error("ERROR: GitHub response for xone has no sha.");
  Deno.exit(1);
}

console.log(commit.sha);

#!/usr/bin/env bash
#MISE description="Re-tag the local image and push it to the registry"
#MISE dir="{{config_root}}"
#USAGE arg "[mode]" help="What to push: 'release' (main) or 'pr'" {
#USAGE   choices "release" "pr"
#USAGE }
#USAGE arg "[number]" help="PR number (required when mode is 'pr')"
# =============================================================================
# Re-tags the locally built image (tag "local", produced by `mise build:image`) to
# the real tags, pushes them and signs each pushed tag with cosign.
#
#   (no mode)        -> nothing is pushed; logs that this is not acceptable.
#   release          -> tags <major>.<UTC-timestamp>, <major>, latest
#                       and pushes ALL THREE. (used on the main branch)
#                       Then keeps the newest RELEASE_TAG_RETENTION timestamp
#                       tags (default: 3) and removes older timestamp-only
#                       package versions from GHCR.
#   pr <number>      -> tags pr-<number> and pushes ONLY pr-<number>.
#
# UTC timestamp format: <major>.<YYYYMMDD>T<HHmm>  e.g. 44.20260706T1432
#
# Registry login beforehand:
#   podman login ghcr.io
# or via env (for CI):
#   REGISTRY_USER / REGISTRY_TOKEN
#
# Cosign signing:
#   certs/cosign.key + COSIGN_PASSWORD
# =============================================================================
set -euo pipefail

# shellcheck source=/dev/null
source ./build.env

# usage args are exposed as environment variables by mise/usage.
MODE="${usage_mode:-}"
NUMBER="${usage_number:-}"

if command -v podman >/dev/null 2>&1; then
  ENGINE="podman"
elif command -v docker >/dev/null 2>&1; then
  ENGINE="docker"
else
  echo "ERROR: neither podman nor docker found." >&2
  exit 1
fi

REPO="${IMAGE_REGISTRY}/${IMAGE_NAME}"
LOCAL_REF="${REPO}:${LOCAL_IMAGE_TAG}"
COSIGN_KEY="${COSIGN_KEY:-certs/cosign.key}"

# --- guard: the local image must exist --------------------------------------
if ! ${ENGINE} image exists "${LOCAL_REF}" 2>/dev/null; then
  echo "ERROR: ${LOCAL_REF} not found. Run \`mise build:image\` first." >&2
  exit 1
fi

# --- no mode: do nothing but log --------------------------------------------
if [[ -z "${MODE}" ]]; then
  echo "==> No push mode given."
  echo "    Pushing without an explicit mode is not acceptable."
  echo "    Use 'mise push release' or 'mise push pr <number>'."
  exit 0
fi

# --- optional non-interactive login (e.g. CI) ------------------------------
if [[ -n "${REGISTRY_USER:-}" && -n "${REGISTRY_TOKEN:-}" ]]; then
  echo "==> Logging in to ${IMAGE_REGISTRY} as ${REGISTRY_USER}"
  echo "${REGISTRY_TOKEN}" | ${ENGINE} login "${IMAGE_REGISTRY}" \
    --username "${REGISTRY_USER}" --password-stdin

  if command -v cosign >/dev/null 2>&1; then
    echo "${REGISTRY_TOKEN}" | cosign login "${IMAGE_REGISTRY}" \
      --username "${REGISTRY_USER}" --password-stdin
  fi
fi

sign_image() {
  local tag="$1"

  if ! command -v cosign >/dev/null 2>&1; then
    echo "ERROR: cosign not found. Run this task through mise." >&2
    exit 1
  fi
  if [[ ! -f "${COSIGN_KEY}" ]]; then
    echo "ERROR: ${COSIGN_KEY} not found. Run \`mise keys\` first." >&2
    exit 1
  fi

  echo "==> Sign ${REPO}:${tag}"
  cosign sign --yes --key "${COSIGN_KEY}" "${REPO}:${tag}"
}

tag_and_push() {
  local tag="$1"
  echo "==> Tag + push ${REPO}:${tag}"
  ${ENGINE} tag "${LOCAL_REF}" "${REPO}:${tag}"
  ${ENGINE} push "${REPO}:${tag}"
  sign_image "${tag}"
}

cleanup_release_tags() {
  local retention="${RELEASE_TAG_RETENTION:-3}"
  local token="${GH_TOKEN:-${REGISTRY_TOKEN:-}}"

  if ! [[ "${retention}" =~ ^[0-9]+$ ]] || [[ "${retention}" -lt 1 ]]; then
    echo "ERROR: RELEASE_TAG_RETENTION must be a positive integer (got: ${retention})." >&2
    exit 1
  fi

  if ! command -v gh >/dev/null 2>&1; then
    echo "    WARNING: gh not found; skipping release timestamp tag cleanup."
    return 0
  fi

  if [[ -z "${token}" ]]; then
    echo "    WARNING: GH_TOKEN/REGISTRY_TOKEN not set; skipping release timestamp tag cleanup."
    return 0
  fi

  local owner package package_api versions_file endpoint
  if [[ "${IMAGE_NAME}" == */* ]]; then
    owner="${IMAGE_NAME%%/*}"
    package="${IMAGE_NAME#*/}"
  else
    owner="${GITHUB_REPOSITORY_OWNER:-}"
    package="${IMAGE_NAME}"
  fi

  if [[ -z "${owner}" || -z "${package}" ]]; then
    echo "    WARNING: cannot derive GHCR owner/package from IMAGE_NAME=${IMAGE_NAME}; skipping cleanup."
    return 0
  fi

  package_api="${package//\//%2F}"
  versions_file="$(mktemp)"

  if GH_TOKEN="${token}" gh api --paginate \
      "/orgs/${owner}/packages/container/${package_api}/versions?per_page=100" \
      --jq '.[] | [.id, (.metadata.container.tags // [] | join(","))] | @tsv' \
      > "${versions_file}" 2>/dev/null; then
    endpoint="/orgs/${owner}/packages/container/${package_api}/versions"
  elif GH_TOKEN="${token}" gh api --paginate \
      "/users/${owner}/packages/container/${package_api}/versions?per_page=100" \
      --jq '.[] | [.id, (.metadata.container.tags // [] | join(","))] | @tsv' \
      > "${versions_file}" 2>/dev/null; then
    endpoint="/users/${owner}/packages/container/${package_api}/versions"
  else
    rm -f "${versions_file}"
    echo "    WARNING: cannot list GHCR package versions for ${owner}/${package}; skipping cleanup."
    return 0
  fi

  local entries=()
  local id tags_csv tag protected timestamp_regex
  timestamp_regex="^${FEDORA_MAJOR_VERSION}\.[0-9]{8}T[0-9]{4}$"

  while IFS=$'\t' read -r id tags_csv; do
    [[ -z "${id}" || -z "${tags_csv}" ]] && continue
    protected=0
    IFS=',' read -r -a tags <<< "${tags_csv}"
    for tag in "${tags[@]}"; do
      if [[ "${tag}" == "latest" || "${tag}" == "${FEDORA_MAJOR_VERSION}" || "${tag}" == pr-* ]]; then
        protected=1
      fi
    done
    for tag in "${tags[@]}"; do
      if [[ "${tag}" =~ ${timestamp_regex} ]]; then
        entries+=("${tag}"$'\t'"${id}"$'\t'"${protected}"$'\t'"${tags_csv}")
      fi
    done
  done < "${versions_file}"
  rm -f "${versions_file}"

  if [[ "${#entries[@]}" -le "${retention}" ]]; then
    echo "==> release tag cleanup: ${#entries[@]} timestamp tags present; keeping all (retention=${retention})"
    return 0
  fi

  echo "==> release tag cleanup: keeping newest ${retention} timestamp tags"
  local sorted=()
  mapfile -t sorted < <(printf '%s\n' "${entries[@]}" | sort -r)

  local index version_id is_protected all_tags
  local deleted_ids=()
  for index in "${!sorted[@]}"; do
    [[ "${index}" -lt "${retention}" ]] && continue

    IFS=$'\t' read -r tag version_id is_protected all_tags <<< "${sorted[${index}]}"
    if [[ "${is_protected}" == "1" ]]; then
      echo "    keep ${tag}: package version also has protected tag(s): ${all_tags}"
      continue
    fi

    if [[ " ${deleted_ids[*]} " == *" ${version_id} "* ]]; then
      continue
    fi

    echo "    delete old timestamp tag ${tag} (package version ${version_id})"
    GH_TOKEN="${token}" gh api --method DELETE "${endpoint}/${version_id}"
    deleted_ids+=("${version_id}")
  done
}

case "${MODE}" in
  release)
    TIMESTAMP="$(date -u +%Y%m%dT%H%M)"
    TS_TAG="${FEDORA_MAJOR_VERSION}.${TIMESTAMP}"
    echo "==> release: pushing ${TS_TAG}, ${FEDORA_MAJOR_VERSION}, latest"
    tag_and_push "${TS_TAG}"
    tag_and_push "${FEDORA_MAJOR_VERSION}"
    tag_and_push "latest"
    cleanup_release_tags
    ;;

  pr)
    if [[ -z "${NUMBER}" ]]; then
      echo "ERROR: mode 'pr' requires a PR number: mise push pr <number>" >&2
      exit 1
    fi
    echo "==> pr: pushing pr-${NUMBER} only"
    tag_and_push "pr-${NUMBER}"
    ;;

  *)
    echo "ERROR: unknown mode '${MODE}' (expected 'release' or 'pr')." >&2
    exit 1
    ;;
esac

echo "==> Push done."

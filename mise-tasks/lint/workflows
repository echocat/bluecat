#!/usr/bin/env bash
#MISE description="Validate GitHub Actions workflow YAML files"
#MISE dir="{{config_root}}"
set -euo pipefail
# GitHub Actions workflows live under .github/workflows/ at the repo root.
for f in .github/workflows/*.yaml; do
  echo "==> ${f}"
  yq eval 'true' "${f}" > /dev/null
done
echo "workflow YAML OK"

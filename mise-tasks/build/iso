#!/usr/bin/env bash
#MISE description="Build the rolling offline installer ISO"
#MISE dir="{{config_root}}"
# =============================================================================
# build:iso  -  offline Anaconda installer ISO
# =============================================================================
# Builds a Fedora boot ISO with an embedded Kickstart and an embedded OCI layout
# of the locally built bluecat bootc image. The ISO build is intentionally a
# local gate before any release image is published.
#
# Output:
#   output/bluecat.iso
#   output/bluecat.iso.sha256
#   output/bluecat.iso.md5
# =============================================================================
set -euo pipefail

# shellcheck source=/dev/null
source ./build.env

if ! command -v podman >/dev/null 2>&1; then
  echo "ERROR: podman not found." >&2
  exit 1
fi

if [[ "${EUID}" -ne 0 ]]; then
  if command -v sudo >/dev/null 2>&1; then
    sudo_cmd=(sudo)
  else
    echo "ERROR: mkksiso needs root for loop devices; sudo not found." >&2
    exit 1
  fi
else
  sudo_cmd=()
fi

OUTPUT_DIR="output"
BASE_ISO="${OUTPUT_DIR}/fedora-boot-${FEDORA_MAJOR_VERSION}.iso"
OUT_ISO="${OUTPUT_DIR}/bluecat.iso"
OCI_DIR="${OUTPUT_DIR}/bluecat.oci"
KS_IN="iso/bluecat.ks.in"
KS_OUT="iso/bluecat.ks"
ISO_ROOTFS="iso/rootfs"
ANACONDA_ROOTFS="iso/product.img"

REPO="${IMAGE_REGISTRY}/${IMAGE_NAME}"
LOCAL_REF="${REPO}:${LOCAL_IMAGE_TAG}"
TARGET_IMAGE_REF="${REPO}:${ISO_IMAGE_TAG}"

mkdir -p "${OUTPUT_DIR}"

echo "==> Engine: podman"
echo "==> Source image: ${LOCAL_REF}"
echo "==> Installed target image ref: ${TARGET_IMAGE_REF}"

if ! podman image exists "${LOCAL_REF}" 2>/dev/null; then
  echo "ERROR: ${LOCAL_REF} not found. Run \`mise build:image\` first." >&2
  exit 1
fi

if [[ ! -f "${KS_IN}" ]]; then
  echo "ERROR: missing ${KS_IN}." >&2
  exit 1
fi
if [[ ! -f "${ANACONDA_ROOTFS}/.buildstamp.in" ]]; then
  echo "ERROR: missing ${ANACONDA_ROOTFS}/.buildstamp.in." >&2
  exit 1
fi
if [[ ! -f "${ANACONDA_ROOTFS}/usr/share/anaconda/anaconda-gtk.css" ]]; then
  echo "ERROR: missing ${ANACONDA_ROOTFS}/usr/share/anaconda/anaconda-gtk.css." >&2
  exit 1
fi
if [[ ! -f "${ANACONDA_ROOTFS}/usr/share/anaconda/pixmaps/sidebar-logo.png" ]]; then
  echo "ERROR: missing ${ANACONDA_ROOTFS}/usr/share/anaconda/pixmaps/sidebar-logo.png; run 'mise branding' and commit the generated file." >&2
  exit 1
fi
if [[ ! -f "${ISO_ROOTFS}/README.txt" ]]; then
  echo "ERROR: missing ${ISO_ROOTFS}/README.txt." >&2
  exit 1
fi
if [[ ! -f "LICENSE" ]]; then
  echo "ERROR: missing project root LICENSE." >&2
  exit 1
fi

echo "==> Rendering Kickstart -> ${KS_OUT}"
sed "s|@@TARGET_IMAGE_REF@@|${TARGET_IMAGE_REF}|g" "${KS_IN}" > "${KS_OUT}"

if [[ -f "${BASE_ISO}" ]]; then
  echo "==> Base ISO already present: ${BASE_ISO} (delete it to force re-download)"
else
  echo "==> Downloading base ISO: ${ISO_BASE_URL}"
  curl -fSL --retry 3 -o "${BASE_ISO}.part" "${ISO_BASE_URL}"
  mv "${BASE_ISO}.part" "${BASE_ISO}"
fi

echo "==> Exporting local image payload -> ${OCI_DIR}"
rm -rf "${OCI_DIR}" "${OCI_DIR}.part"
podman push --compression-format=zstd --compression-level=19 --force-compression \
  "${LOCAL_REF}" "oci:${OCI_DIR}.part:bluecat:local"
mv "${OCI_DIR}.part" "${OCI_DIR}"

loop_devices=()
for d in /dev/loop-control /dev/loop[0-9]*; do
  [[ -e "${d}" ]] && loop_devices+=(--device "${d}")
done

VOLID="bluecat-${FEDORA_MAJOR_VERSION}"

echo "==> Building offline ISO with mkksiso (in ${ISO_BUILDER_IMAGE}, as root)"
"${sudo_cmd[@]}" rm -f "${OUT_ISO}" "${OUT_ISO}.sha256" "${OUT_ISO}.md5"

"${sudo_cmd[@]}" podman run --rm --privileged \
  --pull=newer \
  "${loop_devices[@]}" \
  -e KS_OUT="${KS_OUT}" \
  -e BASE_ISO="${BASE_ISO}" \
  -e OUT_ISO="${OUT_ISO}" \
  -e VOLID="${VOLID}" \
  -e VERSION="${FEDORA_MAJOR_VERSION}" \
  -e ISO_ROOTFS="${ISO_ROOTFS}" \
  -e ANACONDA_ROOTFS="${ANACONDA_ROOTFS}" \
  -e OCI_DIR="${OCI_DIR}" \
  -v "${PWD}:/work:z" \
  -w /work \
  "${ISO_BUILDER_IMAGE}" \
  bash -euo pipefail -c '
    dnf install -y lorax cpio gzip isomd5sum xorriso >/dev/null

    prod=$(mktemp -d)
    add_root=$(mktemp -d)
    mkdir -p "${add_root}/images"

    cp -a "${ANACONDA_ROOTFS}/." "${prod}/"
    sed -e "s|@@VERSION@@|${VERSION}|g" \
        -e "s|@@UUID@@|$(date -u +%Y%m%d%H%M).bluecat|g" \
        "${prod}/.buildstamp.in" > "${prod}/.buildstamp"
    rm -f "${prod}/.buildstamp.in"

    ( cd "${prod}" && find . | cpio -o -H newc --quiet | gzip -9 ) \
      > "${add_root}/images/product.img"

    cp -a "${OCI_DIR}" "${add_root}/images/bluecat.oci"

    add_args=(-a "${add_root}/images" -a LICENSE)
    for add_path in "${ISO_ROOTFS}"/*; do
      [[ -e "${add_path}" ]] || continue
      add_args+=(-a "${add_path}")
    done

    mkksiso \
      --ks "${KS_OUT}" \
      -V "${VOLID}" \
      -R "Install Fedora ${VERSION}" "Install bluecat ${VERSION}" \
      -R "Test this media & install Fedora ${VERSION}" "Test this media & install bluecat ${VERSION}" \
      -R "Rescue a Fedora system" "Rescue a bluecat system" \
      "${add_args[@]}" \
      "${BASE_ISO}" "${OUT_ISO}"

    if osirrox -indev "${OUT_ISO}" -find /Fedora-Legal-README.txt >/dev/null 2>&1; then
      xorriso -boot_image any keep \
        -dev "${OUT_ISO}" \
        -rm /Fedora-Legal-README.txt -- >/dev/null 2>&1 || \
        echo "    WARNING: could not remove Fedora-Legal-README.txt"
    fi

    implantisomd5 --force --supported-iso "${OUT_ISO}"
    checkisomd5 --verbose "${OUT_ISO}"
  '

"${sudo_cmd[@]}" chown "$(id -u):$(id -g)" "${OUT_ISO}"

echo "==> Writing checksums"
(
  cd "${OUTPUT_DIR}"
  sha256sum bluecat.iso > bluecat.iso.sha256
  md5sum bluecat.iso > bluecat.iso.md5
)

echo
echo "==> Done: ${OUT_ISO}"
if command -v du >/dev/null 2>&1; then
  echo "    Size: $(du -h "${OUT_ISO}" | cut -f1)"
fi
echo "    Embedded payload: ${LOCAL_REF}"
echo "    Installed target: ${TARGET_IMAGE_REF}"
echo "    Checksums: ${OUT_ISO}.sha256, ${OUT_ISO}.md5"

#!/usr/bin/env bash
#MISE description="Publish the chunked OCI layout to the registry"
#MISE dir="{{config_root}}"
#USAGE arg "[mode]" help="What to push: 'release' (main), 'pr', or 'test'" {
#USAGE   choices "release" "pr" "test"
#USAGE }
#USAGE arg "[number]" help="PR number, or test name (required when mode is 'pr' or 'test')"
# =============================================================================
# Publishes the locally built chunked OCI layout to the real tags and signs each
# unique pushed image digest with cosign.
#
#   (no mode)        -> nothing is pushed; logs that this is not acceptable.
#   release          -> tags <major>.<UTC-timestamp>, <major>
#                       and pushes BOTH. (used on the main branch)
#                       Then signs the release digest once and aliases the
#                       signature as <major>.<UTC-timestamp>.sig while keeping
#                       cosign's standard sha256-<image-digest>.sig tag.
#                       Then keeps the newest RELEASE_TAG_RETENTION timestamp
#                       tags (default: 3) and removes older timestamp/signature
#                       package versions from GHCR.
#   pr <number>      -> tags pr-<number> and pushes ONLY pr-<number>.
#   test <name>      -> tags test-<name>-<UTC-timestamp> and test-<name>,
#                       signs only the timestamp tag, and aliases the signature
#                       as test-<name>-<UTC-timestamp>.sig. Does not clean up
#                       registry tags.
#
# UTC timestamp format: <major>.<YYYYMMDD>T<HHmm>  e.g. 44.20260706T1432
#
# Registry login beforehand:
#   podman login ghcr.io
# or via env (for CI):
#   REGISTRY_USER / REGISTRY_TOKEN
#
# Cosign signing:
#   certs/cosign.key + COSIGN_PASSWORD
#   Cosign v3 must disable the signing config and use the old bundle format
#   until rpm-ostree/containers.image can verify the new bundle format.
# =============================================================================
set -euo pipefail

# shellcheck source=/dev/null

# usage args are exposed as environment variables by mise/usage.
MODE="${usage_mode:-}"
NUMBER="${usage_number:-}"

if ! command -v podman >/dev/null 2>&1; then
  echo "ERROR: podman not found." >&2
  exit 1
fi

if ! command -v skopeo >/dev/null 2>&1; then
  echo "ERROR: skopeo not found." >&2
  exit 1
fi

REPO="${IMAGE_REGISTRY}/${IMAGE_NAME}"
OUTPUT_DIR="output"
CHUNKED_OCI="${OUTPUT_DIR}/bluecat.oci"
CHUNKED_OCI_REF="bluecat:${LOCAL_CHUNKED_IMAGE_TAG}"
COSIGN_KEY="${COSIGN_KEY:-certs/cosign.key}"

# --- guard: the chunked OCI layout must exist -------------------------------
if [[ ! -f "${CHUNKED_OCI}/index.json" ]]; then
  echo "ERROR: ${CHUNKED_OCI} not found. Run \`mise build:chunked-image\` first." >&2
  exit 1
fi
if ! skopeo inspect "oci:${CHUNKED_OCI}:${CHUNKED_OCI_REF}" >/dev/null; then
  echo "ERROR: ${CHUNKED_OCI} does not contain ${CHUNKED_OCI_REF}. Run \`mise build:chunked-image\` first." >&2
  exit 1
fi

# --- no mode: do nothing but log --------------------------------------------
if [[ -z "${MODE}" ]]; then
  echo "==> No push mode given."
  echo "    Pushing without an explicit mode is not acceptable."
  echo "    Use 'mise publish:image release', 'mise publish:image pr <number>', or 'mise publish:image test <name>'."
  exit 0
fi

# --- optional non-interactive login (e.g. CI) ------------------------------
if [[ -n "${REGISTRY_USER:-}" && -n "${REGISTRY_TOKEN:-}" ]]; then
  echo "==> Logging in to ${IMAGE_REGISTRY} as ${REGISTRY_USER}"
  echo "${REGISTRY_TOKEN}" | podman login "${IMAGE_REGISTRY}" \
    --username "${REGISTRY_USER}" --password-stdin

  if command -v cosign >/dev/null 2>&1; then
    echo "${REGISTRY_TOKEN}" | cosign login "${IMAGE_REGISTRY}" \
      --username "${REGISTRY_USER}" --password-stdin
  fi
fi

sign_image_ref() {
  local ref="$1"

  if ! command -v cosign >/dev/null 2>&1; then
    echo "ERROR: cosign not found. Run this task through mise." >&2
    exit 1
  fi
  if [[ ! -f "${COSIGN_KEY}" ]]; then
    echo "ERROR: ${COSIGN_KEY} not found. Run \`mise keys\` first." >&2
    exit 1
  fi

  echo "==> Sign ${ref}"
  cosign sign --yes --use-signing-config=false --new-bundle-format=false \
    --key "${COSIGN_KEY}" "${ref}"
}

push_image_tag() {
  local tag="$1"
  echo "==> Push ${CHUNKED_OCI}:${CHUNKED_OCI_REF} -> ${REPO}:${tag} (zstd)"
  skopeo copy \
    --dest-compress-format=zstd \
    --dest-compress-level=19 \
    --dest-force-compress-format \
    "oci:${CHUNKED_OCI}:${CHUNKED_OCI_REF}" \
    "docker://${REPO}:${tag}"
}

copy_image_tag() {
  local source_tag="$1"
  local target_tag="$2"

  echo "==> Copy ${REPO}:${source_tag} -> ${REPO}:${target_tag}"
  skopeo copy --preserve-digests \
    "docker://${REPO}:${source_tag}" \
    "docker://${REPO}:${target_tag}"
}

image_digest_for_tag() {
  local tag="$1"
  skopeo inspect --format '{{.Digest}}' "docker://${REPO}:${tag}"
}

signature_tag_for_digest() {
  local digest="$1"
  printf 'sha256-%s.sig\n' "${digest#sha256:}"
}

alias_signature_tag() {
  local digest="$1"
  local alias_tag="$2"
  local signature_tag

  signature_tag="$(signature_tag_for_digest "${digest}")"
  echo "==> Alias signature ${REPO}:${signature_tag} as ${REPO}:${alias_tag}"
  skopeo copy --preserve-digests \
    "docker://${REPO}:${signature_tag}" \
    "docker://${REPO}:${alias_tag}"
}

is_cosign_signature_manifest() {
  local ref="$1"
  local raw

  if ! raw="$(skopeo inspect --raw "docker://${ref}" 2>/dev/null)"; then
    echo "    WARNING: cannot inspect ${ref}; keeping it." >&2
    return 1
  fi

  [[ "${raw}" == *"application/vnd.dev.cosign.simplesigning.v1+json"* ]]
}

cleanup_release_tags() {
  local retention="${RELEASE_TAG_RETENTION:-3}"
  local token="${GH_TOKEN:-${REGISTRY_TOKEN:-}}"

  if ! [[ "${retention}" =~ ^[0-9]+$ ]] || [[ "${retention}" -lt 1 ]]; then
    echo "ERROR: RELEASE_TAG_RETENTION must be a positive integer (got: ${retention})." >&2
    exit 1
  fi

  if ! command -v gh >/dev/null 2>&1; then
    echo "    WARNING: gh not found; skipping release timestamp tag cleanup."
    return 0
  fi

  if [[ -z "${token}" ]]; then
    echo "    WARNING: GH_TOKEN/REGISTRY_TOKEN not set; skipping release timestamp tag cleanup."
    return 0
  fi

  local owner package package_api versions_file endpoint
  if [[ "${IMAGE_NAME}" == */* ]]; then
    owner="${IMAGE_NAME%%/*}"
    package="${IMAGE_NAME#*/}"
  else
    owner="${GITHUB_REPOSITORY_OWNER:-}"
    package="${IMAGE_NAME}"
  fi

  if [[ -z "${owner}" || -z "${package}" ]]; then
    echo "    WARNING: cannot derive GHCR owner/package from IMAGE_NAME=${IMAGE_NAME}; skipping cleanup."
    return 0
  fi

  package_api="${package//\//%2F}"
  versions_file="$(mktemp)"

  if GH_TOKEN="${token}" gh api --paginate \
      "/orgs/${owner}/packages/container/${package_api}/versions?per_page=100" \
      --jq '.[] | [.id, .name, (.metadata.container.tags // [] | join(","))] | @tsv' \
      > "${versions_file}" 2>/dev/null; then
    endpoint="/orgs/${owner}/packages/container/${package_api}/versions"
  elif GH_TOKEN="${token}" gh api --paginate \
      "/users/${owner}/packages/container/${package_api}/versions?per_page=100" \
      --jq '.[] | [.id, .name, (.metadata.container.tags // [] | join(","))] | @tsv' \
      > "${versions_file}" 2>/dev/null; then
    endpoint="/users/${owner}/packages/container/${package_api}/versions"
  else
    rm -f "${versions_file}"
    echo "    WARNING: cannot list GHCR package versions for ${owner}/${package}; skipping cleanup."
    return 0
  fi

  local entries=()
  local id name tags_csv tag protected timestamp_regex timestamp_signature_regex cosign_signature_regex
  local -A version_names=()
  local -A version_tags=()
  local -A retained_image_digests=()
  local -A retained_timestamp_tags=()
  local -A deleted_ids=()
  timestamp_regex="^${FEDORA_MAJOR_VERSION}\.[0-9]{8}T[0-9]{4}$"
  timestamp_signature_regex="^${FEDORA_MAJOR_VERSION}\.[0-9]{8}T[0-9]{4}\.sig$"
  cosign_signature_regex='^sha256-[0-9a-f]{64}(\.sig)?$'

  while IFS=$'\t' read -r id name tags_csv; do
    [[ -z "${id}" || -z "${name}" ]] && continue
    version_names["${id}"]="${name}"
    version_tags["${id}"]="${tags_csv}"

    protected=0
    IFS=',' read -r -a tags <<< "${tags_csv}"
    for tag in "${tags[@]}"; do
      if [[ "${tag}" == "${FEDORA_MAJOR_VERSION}" || "${tag}" == pr-* ]]; then
        protected=1
        if [[ "${name}" == sha256:* ]]; then
          retained_image_digests["${name}"]=1
        fi
      fi
    done
    for tag in "${tags[@]}"; do
      if [[ "${tag}" =~ ${timestamp_regex} ]]; then
        entries+=("${tag}"$'\t'"${id}"$'\t'"${protected}"$'\t'"${tags_csv}"$'\t'"${name}")
      fi
    done
  done < "${versions_file}"

  if [[ "${#entries[@]}" -le "${retention}" ]]; then
    echo "==> release tag cleanup: ${#entries[@]} timestamp tags present; keeping all (retention=${retention})"
  else
    echo "==> release tag cleanup: keeping newest ${retention} timestamp tags"
  fi

  local sorted=()
  if [[ "${#entries[@]}" -gt 0 ]]; then
    mapfile -t sorted < <(printf '%s\n' "${entries[@]}" | sort -r)
  fi

  local index version_id is_protected all_tags version_name
  for index in "${!sorted[@]}"; do
    IFS=$'\t' read -r tag version_id is_protected all_tags version_name <<< "${sorted[${index}]}"
    if [[ "${index}" -lt "${retention}" ]]; then
      retained_timestamp_tags["${tag}"]=1
      if [[ "${version_name}" == sha256:* ]]; then
        retained_image_digests["${version_name}"]=1
      fi
      continue
    fi

    if [[ "${is_protected}" == "1" ]]; then
      echo "    keep ${tag}: package version also has protected tag(s): ${all_tags}"
      if [[ "${version_name}" == sha256:* ]]; then
        retained_image_digests["${version_name}"]=1
      fi
      continue
    fi

    echo "    delete old timestamp tag ${tag} (package version ${version_id})"
    GH_TOKEN="${token}" gh api --method DELETE "${endpoint}/${version_id}"
    deleted_ids["${version_id}"]=1
  done

  echo "==> signature cleanup: removing old cosign signature versions"
  local has_signature_tag keep_signature delete_signature target_digest timestamp_tag
  for version_id in "${!version_names[@]}"; do
    if [[ -n "${deleted_ids[${version_id}]:-}" ]]; then
      continue
    fi

    version_name="${version_names[${version_id}]}"
    tags_csv="${version_tags[${version_id}]}"
    has_signature_tag=0
    keep_signature=0
    delete_signature=0
    IFS=',' read -r -a tags <<< "${tags_csv}"

    for tag in "${tags[@]}"; do
      [[ -z "${tag}" ]] && continue

      if [[ "${tag}" == "${FEDORA_MAJOR_VERSION}" || "${tag}" == pr-* || "${tag}" =~ ${timestamp_regex} ]]; then
        keep_signature=1
      elif [[ "${tag}" =~ ${cosign_signature_regex} ]]; then
        has_signature_tag=1
        target_digest="sha256:${tag#sha256-}"
        target_digest="${target_digest%.sig}"
        if [[ -n "${retained_image_digests[${target_digest}]:-}" ]]; then
          keep_signature=1
        else
          delete_signature=1
        fi
      elif [[ "${tag}" =~ ${timestamp_signature_regex} ]]; then
        has_signature_tag=1
        timestamp_tag="${tag%.sig}"
        if [[ -n "${retained_timestamp_tags[${timestamp_tag}]:-}" ]]; then
          keep_signature=1
        else
          delete_signature=1
        fi
      else
        keep_signature=1
      fi
    done

    if [[ "${keep_signature}" == "1" ]]; then
      continue
    fi

    if [[ -z "${tags_csv}" && "${version_name}" == sha256:* ]]; then
      if is_cosign_signature_manifest "${REPO}@${version_name}"; then
        echo "    delete untagged cosign signature package version ${version_id} (${version_name})"
        GH_TOKEN="${token}" gh api --method DELETE "${endpoint}/${version_id}"
        deleted_ids["${version_id}"]=1
      fi
    elif [[ "${has_signature_tag}" == "1" && "${delete_signature}" == "1" ]]; then
      if is_cosign_signature_manifest "${REPO}@${version_name}"; then
        echo "    delete old cosign signature package version ${version_id} (${tags_csv})"
        GH_TOKEN="${token}" gh api --method DELETE "${endpoint}/${version_id}"
        deleted_ids["${version_id}"]=1
      fi
    fi
  done

  rm -f "${versions_file}"
}

case "${MODE}" in
  release)
    TIMESTAMP="$(date -u +%Y%m%dT%H%M)"
    TS_TAG="${FEDORA_MAJOR_VERSION}.${TIMESTAMP}"
    TS_SIG_TAG="${TS_TAG}.sig"
    echo "==> release: pushing ${TS_TAG}, ${FEDORA_MAJOR_VERSION}"
    push_image_tag "${TS_TAG}"
    copy_image_tag "${TS_TAG}" "${FEDORA_MAJOR_VERSION}"
    DIGEST="$(image_digest_for_tag "${TS_TAG}")"
    sign_image_ref "${REPO}@${DIGEST}"
    alias_signature_tag "${DIGEST}" "${TS_SIG_TAG}"
    cleanup_release_tags
    ;;

  pr)
    if [[ -z "${NUMBER}" ]]; then
      echo "ERROR: mode 'pr' requires a PR number: mise publish:image pr <number>" >&2
      exit 1
    fi
    echo "==> pr: pushing pr-${NUMBER} only"
    PR_TAG="pr-${NUMBER}"
    push_image_tag "${PR_TAG}"
    DIGEST="$(image_digest_for_tag "${PR_TAG}")"
    sign_image_ref "${REPO}@${DIGEST}"
    ;;

  test)
    if [[ -z "${NUMBER}" ]]; then
      echo "ERROR: mode 'test' requires a name: mise publish:image test <name>" >&2
      exit 1
    fi
    if ! [[ "${NUMBER}" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]]; then
      echo "ERROR: test name must match [A-Za-z0-9][A-Za-z0-9_.-]* (got: ${NUMBER})." >&2
      exit 1
    fi

    TIMESTAMP="$(date -u +%Y%m%dT%H%M)"
    TEST_TAG="test-${NUMBER}"
    TEST_TS_TAG="${TEST_TAG}-${TIMESTAMP}"
    TEST_TS_SIG_TAG="${TEST_TS_TAG}.sig"
    echo "==> test: pushing ${TEST_TS_TAG}, ${TEST_TAG}"
    push_image_tag "${TEST_TS_TAG}"
    copy_image_tag "${TEST_TS_TAG}" "${TEST_TAG}"
    DIGEST="$(image_digest_for_tag "${TEST_TS_TAG}")"
    sign_image_ref "${REPO}@${DIGEST}"
    alias_signature_tag "${DIGEST}" "${TEST_TS_SIG_TAG}"
    ;;

  *)
    echo "ERROR: unknown mode '${MODE}' (expected 'release', 'pr', or 'test')." >&2
    exit 1
    ;;
esac

echo "==> Image publish done."

#!/usr/bin/env -S deno run --allow-net --allow-read --allow-write --allow-run --allow-env=COSIGN_PASSWORD
//MISE description="Generate the Secure Boot MOK and Cosign signing keys (run once)"
//MISE dir="{{config_root}}"
//MISE tools={deno="latest"}
// ===========================================================================
// Generates the signing material ONCE:
//   - self-signed MOK (Machine Owner Key), used to sign kernel modules
//   - Cosign keypair, used to sign the pushed OCI image
// The MOK X.509 certificate is produced with @peculiar/x509 via Web Crypto.
// The Cosign keypair is produced by cosign itself (provided by mise).
//
//   certs/mok.key  -> PRIVATE key   (NEVER commit! blocked by .gitignore.)
//   certs/mok.crt  -> PUBLIC cert (PEM, used for signing)
//   certs/mok.der  -> PUBLIC cert (DER, for mokutil / firmware enrollment)
//
// For CI: store the content of certs/mok.key as secret MOK_KEY, and
// certs/mok.crt / certs/mok.der as secrets MOK_CRT / MOK_DER_B64 (base64).
// Store certs/cosign.key / certs/cosign.pub as COSIGN_KEY / COSIGN_PUB and the
// key password as COSIGN_PASSWORD.
// ===========================================================================
import * as x509 from "npm:@peculiar/x509@1.12.3";

// --- read the relevant values from build.env -------------------------------
const buildEnv = await Deno.readTextFile("build.env");
function envValue(name: string, fallback: string): string {
  // Match lines like:  NAME="value"   (ignoring inline comments after the value)
  const re = new RegExp(`^${name}="([^"]*)"`, "m");
  const m = buildEnv.match(re);
  return m ? m[1] : fallback;
}

const MOK_KEY = envValue("MOK_KEY", "certs/mok.key");
const MOK_CERT_CRT = envValue("MOK_CERT_CRT", "certs/mok.crt");
const MOK_CERT_DER = envValue("MOK_CERT_DER", "certs/mok.der");
const COSIGN_KEY = "certs/cosign.key";
const COSIGN_PUB = "certs/cosign.pub";
// Strip the surrounding slashes of the openssl-style subject (/CN=.../).
const SUBJECT = envValue("MOK_SUBJECT", "/CN=echocat Secure Boot Signing/")
  .replace(/^\//, "")
  .replace(/\/$/, "");

// --- guard: never overwrite an existing key --------------------------------
async function exists(path: string): Promise<boolean> {
  try {
    await Deno.stat(path);
    return true;
  } catch {
    return false;
  }
}

await Deno.mkdir("certs", { recursive: true });

// --- generate a 4096-bit RSA key + self-signed cert, valid 15 years ---------
x509.cryptoProvider.set(globalThis.crypto);

const mokFiles = [MOK_KEY, MOK_CERT_CRT, MOK_CERT_DER];
const existingMokFiles = await existingFiles(mokFiles);
if (existingMokFiles.length === 0) {
  await generateMok();
} else if (existingMokFiles.length === mokFiles.length) {
  console.log(`==> MOK already exists; keeping ${MOK_KEY}`);
} else {
  console.error(
    `ERROR: incomplete MOK material: ${existingMokFiles.join(", ")}`,
  );
  console.error(
    `       Expected either none or all of: ${mokFiles.join(", ")}`,
  );
  Deno.exit(1);
}

const cosignFiles = [COSIGN_KEY, COSIGN_PUB];
const existingCosignFiles = await existingFiles(cosignFiles);
if (existingCosignFiles.length === 0) {
  await generateCosign();
} else if (existingCosignFiles.length === cosignFiles.length) {
  console.log(`==> Cosign keypair already exists; keeping ${COSIGN_KEY}`);
} else {
  console.error(
    `ERROR: incomplete Cosign material: ${existingCosignFiles.join(", ")}`,
  );
  console.error(
    `       Expected either none or all of: ${cosignFiles.join(", ")}`,
  );
  Deno.exit(1);
}

console.log();
console.log("==> Done:");
console.log(`    MOK PRIVATE (do not commit):     ${MOK_KEY}`);
console.log(`    MOK PUBLIC (PEM):                ${MOK_CERT_CRT}`);
console.log(`    MOK PUBLIC (DER):                ${MOK_CERT_DER}`);
console.log(`    COSIGN PRIVATE (do not commit):  ${COSIGN_KEY}`);
console.log(`    COSIGN PUBLIC:                   ${COSIGN_PUB}`);
console.log();
console.log(
  "Next step: enroll the public MOK cert into the firmware (see README):",
);
console.log(`    sudo mokutil --import ${MOK_CERT_DER}`);

async function existingFiles(paths: string[]): Promise<string[]> {
  const result: string[] = [];
  for (const path of paths) {
    if (await exists(path)) result.push(path);
  }
  return result;
}

async function generateMok() {
  console.log("==> Generating 4096-bit RSA MOK, valid for 15 years");
  const alg: RsaHashedKeyGenParams = {
    name: "RSASSA-PKCS1-v1_5",
    hash: "SHA-256",
    modulusLength: 4096,
    publicExponent: new Uint8Array([1, 0, 1]),
  };
  const keys = await crypto.subtle.generateKey(alg, true, ["sign", "verify"]);
  const subjectKeyIdentifier = await x509.SubjectKeyIdentifierExtension.create(
    keys.publicKey,
  );

  const notBefore = new Date();
  const notAfter = new Date(notBefore.getTime() + 15 * 365 * 24 * 3600 * 1000);

  const cert = await x509.X509CertificateGenerator.createSelfSigned({
    serialNumber: "01",
    name: SUBJECT,
    notBefore,
    notAfter,
    signingAlgorithm: alg,
    keys,
    extensions: [
      new x509.BasicConstraintsExtension(false, undefined, true),
      new x509.KeyUsagesExtension(x509.KeyUsageFlags.digitalSignature, false),
      subjectKeyIdentifier,
      new x509.ExtendedKeyUsageExtension(
        ["1.3.6.1.5.5.7.3.3", "1.3.6.1.4.1.2312.16.1.2"],
        false,
      ),
    ],
  });

  const crtPem = cert.toString("pem");
  const pkcs8 = await crypto.subtle.exportKey("pkcs8", keys.privateKey);
  const keyPem = x509.PemConverter.encode(pkcs8, "PRIVATE KEY");
  const der = new Uint8Array(cert.rawData);

  await Deno.writeTextFile(MOK_KEY, keyPem + "\n");
  await Deno.writeTextFile(MOK_CERT_CRT, crtPem + "\n");
  await Deno.writeFile(MOK_CERT_DER, der);

  await Deno.chmod(MOK_KEY, 0o600);
  await Deno.chmod(MOK_CERT_CRT, 0o644);
  await Deno.chmod(MOK_CERT_DER, 0o644);
  console.log("==> Generating DER variant (for mokutil)");
}

async function generateCosign() {
  console.log("==> Generating Cosign keypair");
  const command = new Deno.Command("cosign", {
    args: ["generate-key-pair"],
    cwd: "certs",
    stdin: "inherit",
    stdout: "inherit",
    stderr: "inherit",
  });
  const status = await command.spawn().status;
  if (!status.success) {
    console.error("ERROR: cosign generate-key-pair failed.");
    Deno.exit(status.code);
  }
  await Deno.chmod(COSIGN_KEY, 0o600);
  await Deno.chmod(COSIGN_PUB, 0o644);
}

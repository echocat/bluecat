#!/usr/bin/env -S deno run --allow-net --allow-read --allow-write
//MISE description="Render the echocat branding assets from SVG into image/rootfs/, iso/ and site/"
//MISE dir="{{config_root}}"
// ===========================================================================
// Renders the bluecat / echocat branding from the source SVGs in
// assets/branding/ into the paths the image and ISO expect. The generated files
// are meant to be committed; the builds then simply copy/use those files.
//
// SVG -> PNG rendering is done in pure Deno via the resvg WebAssembly build
// (@resvg/resvg-wasm) — no native CLI dependency (no rsvg-convert/ImageMagick).
//
//   mise branding      # (re)generate all branding assets
//
// Re-run this whenever the source SVGs in assets/branding/ change.
// ===========================================================================
import { initWasm, Resvg } from "npm:@resvg/resvg-wasm@2.6.2";
import TextToSVG from "npm:text-to-svg@3.1.5";

// --- sources ---------------------------------------------------------------
const SRC_DIR = "assets/branding";
const SRC_SYMBOL = `${SRC_DIR}/bluecat-logo-symbol.svg`; // square mark
const SRC_FULL = `${SRC_DIR}/bluecat-logo.svg`; // mark + wordmark
const SRC_WHITE = `${SRC_DIR}/bluecat-logo-white.svg`; // white mark + wordmark

// --- output roots (inside image/rootfs/, copied into the image at /) --------
const OUT = "image/rootfs";
const PIXMAPS = `${OUT}/usr/share/pixmaps`;
const HICOLOR = `${OUT}/usr/share/icons/hicolor`;
const SDDM_ASSETS = `${OUT}/usr/share/sddm/themes/bluecat`;
const ISO_ANACONDA_ROOTFS = "iso/product.img";
const SITE_STATIC = "site/static";
// The Plymouth watermark must NOT be shipped straight into the rpm-managed
// theme dir (/usr/share/plymouth/themes/spinner): a later `rpm-ostree install`
// re-checks out that package directory and drops non-packaged files. We stage
// it in our own (non-packaged) branding dir; 800-rebranding copies it into the
// spinner theme AFTER the last rpm-ostree transaction.
const BRANDING = `${OUT}/usr/share/bluecat/branding`;

// Icon name referenced by os-release LOGO (see image/setup/stage2.d/800-rebranding).
const ICON_NAME = "bluecat-logo-icon";
// Icon sizes for the hicolor theme.
const ICON_SIZES = [16, 22, 24, 32, 48, 64, 128, 256];

// The resvg wasm module. --allow-net is used to fetch it (accepted trade-off);
// it is cached by Deno after the first run.
const WASM_URL = "https://esm.sh/@resvg/resvg-wasm@2.6.2/index_bg.wasm";
const SOCIAL_TEXT = TextToSVG.loadSync();

// ---------------------------------------------------------------------------
async function ensureDir(path: string): Promise<void> {
  await Deno.mkdir(path, { recursive: true });
}

async function readSvg(path: string): Promise<string> {
  try {
    return await Deno.readTextFile(path);
  } catch {
    console.error(`ERROR: missing source SVG: ${path}`);
    console.error("       Place the echocat branding SVGs in assets/branding/.");
    Deno.exit(1);
  }
}

// Render an SVG string to a PNG of the given pixel width (height keeps aspect).
function renderPng(svg: string, width: number): Uint8Array {
  const resvg = new Resvg(svg, { fitTo: { mode: "width", value: width } });
  return resvg.render().asPng();
}

function svgBody(svg: string): string {
  const match = svg.match(/<svg[^>]*>([\s\S]*)<\/svg>/);
  if (match === null) {
    console.error("ERROR: source SVG has no <svg> root");
    Deno.exit(1);
  }
  return match[1];
}

function textPath(text: string, x: number, y: number, fontSize: number, fill: string): string {
  return SOCIAL_TEXT.getPath(text, {
    x,
    y,
    fontSize,
    attributes: { fill },
  });
}

function socialCardSvg(symbolSvg: string): string {
  return `
<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#040711"/>
      <stop offset="0.48" stop-color="#081a2b"/>
      <stop offset="1" stop-color="#03060d"/>
    </linearGradient>
    <radialGradient id="glow" cx="0.2" cy="0.15" r="0.85">
      <stop offset="0" stop-color="#006fb3" stop-opacity="0.65"/>
      <stop offset="1" stop-color="#006fb3" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <rect width="1200" height="630" fill="url(#glow)"/>
  <g opacity="0.08" fill="#fff" transform="translate(740 86) scale(2.46)">
    ${svgBody(symbolSvg)}
  </g>
  ${textPath("BOOTC + KDE PLASMA + FEDORA ATOMIC ROOTS", 72, 104, 24, "#82e7ff")}
  ${textPath("bluecat", 72, 238, 108, "#edf8ff")}
  ${textPath("Atomic KDE Desktop", 76, 332, 66, "#edf8ff")}
  ${textPath("An unofficial Kinoite-style bootc image with NVIDIA,", 76, 408, 30, "#d5ecfa")}
  ${textPath("gaming defaults and a rolling offline installer ISO.", 76, 452, 30, "#d5ecfa")}
  <rect x="72" y="520" width="360" height="56" rx="28" fill="#82e7ff"/>
  ${textPath("bluecat.echocat.org", 104, 557, 24, "#001521")}
</svg>`;
}

async function writeFile(path: string, data: Uint8Array): Promise<void> {
  await ensureDir(path.substring(0, path.lastIndexOf("/")));
  await Deno.writeFile(path, data);
  console.log(`    wrote ${path}`);
}

async function copyText(src: string, dest: string): Promise<void> {
  await ensureDir(dest.substring(0, dest.lastIndexOf("/")));
  await Deno.writeTextFile(dest, await Deno.readTextFile(src));
  console.log(`    wrote ${dest}`);
}

// ---------------------------------------------------------------------------
console.log("==> Initializing resvg (wasm)");
await initWasm(fetch(new URL(WASM_URL)));

const symbolSvg = await readSvg(SRC_SYMBOL);
const fullSvg = await readSvg(SRC_FULL);
const whiteSvg = await readSvg(SRC_WHITE);

// --- 1. os-release LOGO + app icon (square symbol) --------------------------
// Ship the SVG itself as the scalable icon, plus hicolor PNGs at fixed sizes.
console.log("==> Icon (os-release LOGO / KDE About / app icon)");
await copyText(SRC_SYMBOL, `${PIXMAPS}/${ICON_NAME}.svg`);
// KDE's kinfocenter "About this System" reads a fixed file path from
// kcm-about-distrorc (LogoPath=), not the os-release LOGO icon name, so it
// needs a real raster file. Ship a square PNG next to the SVG for it.
await writeFile(`${PIXMAPS}/${ICON_NAME}.png`, renderPng(symbolSvg, 256));
// Also ship a scalable hicolor entry.
await copyText(SRC_SYMBOL, `${HICOLOR}/scalable/apps/${ICON_NAME}.svg`);
for (const size of ICON_SIZES) {
  const png = renderPng(symbolSvg, size);
  await writeFile(`${HICOLOR}/${size}x${size}/apps/${ICON_NAME}.png`, png);
}

// --- 2. full logo (mark + wordmark) as a general-purpose pixmap -------------
console.log("==> Full logo pixmap (mark + wordmark)");
await copyText(SRC_FULL, `${PIXMAPS}/bluecat-logo.svg`);
await writeFile(`${PIXMAPS}/bluecat-logo.png`, renderPng(fullSvg, 838));

// --- 3. Plymouth watermark (boot splash) ------------------------------------
// Kinoite uses the "bgrt" theme, which shows the watermark.png from the
// "spinner" theme dir. That dir is rpm-managed, so we stage the watermark in
// our own branding dir and let 800-rebranding place it into spinner/ AFTER the
// last rpm-ostree transaction (otherwise it gets dropped). We use the colored
// wordmark (#006fb3) at a modest width so it does not dominate the splash.
console.log("==> Plymouth watermark (staged in branding dir)");
await writeFile(`${BRANDING}/plymouth-watermark.png`, renderPng(fullSvg, 150));

// --- 4. SDDM login logo -----------------------------------------------------
// Provide the logo as an asset; wiring a specific SDDM theme to show it is
// documented (see docs / assets/branding/README.md). We ship the white
// wordmark (login screens tend to be dark) plus the symbol.
console.log("==> SDDM login logo assets");
await writeFile(`${SDDM_ASSETS}/logo.png`, renderPng(whiteSvg, 500));
await writeFile(`${SDDM_ASSETS}/symbol.png`, renderPng(symbolSvg, 256));

// --- 5. Anaconda installer logo asset ---------------------------------------
// This path mirrors where the file lands inside the temporary product.img.
console.log("==> Anaconda installer logo asset");
await writeFile(
  `${ISO_ANACONDA_ROOTFS}/usr/share/anaconda/pixmaps/sidebar-logo.png`,
  renderPng(whiteSvg, 146),
);

// --- 6. Website social sharing card -----------------------------------------
console.log("==> Website social sharing card");
await writeFile(`${SITE_STATIC}/social-card.png`, renderPng(socialCardSvg(symbolSvg), 1200));

console.log();
console.log("==> Branding assets generated under image/rootfs/, iso/ and site/.");
console.log("    Review + commit the generated files.");

#!/usr/bin/env bash
set -euo pipefail

if [[ "${EUID}" -ne 0 ]]; then
  echo "ERROR: run this script as root, for example via: curl ... | sudo bash" >&2
  exit 1
fi

RAW_BASE="${BLUECAT_RAW_BASE:-https://raw.githubusercontent.com/echocat/bluecat/main}"
IMAGE_REF="${BLUECAT_IMAGE_REF:-ghcr.io/echocat/bluecat:44}"
TMP_DIR="$(mktemp -d)"
POLICY="/etc/containers/policy.json"
REGISTRIES_CONFIG="/etc/containers/registries.d/bluecat.yaml"

cleanup() {
  rm -rf "${TMP_DIR}"
}
trap cleanup EXIT

echo "=== Downloading cosign.pub..."
curl -fsSL "${RAW_BASE}/certs/cosign.pub" -o "${TMP_DIR}/bluecat-cosign.pub"
echo "=== Downloading containers policy..."
curl -fsSL "${RAW_BASE}/image/rootfs/etc/containers/policy.json" \
  -o "${TMP_DIR}/policy.json"
echo "=== Downloading registry signature config..."
curl -fsSL "${RAW_BASE}/image/rootfs/etc/containers/registries.d/bluecat.yaml" \
  -o "${TMP_DIR}/bluecat.yaml"

install -D -m 0644 "${TMP_DIR}/bluecat-cosign.pub" \
  /etc/pki/containers/bluecat-cosign.pub

install -D -m 0644 "${TMP_DIR}/bluecat.yaml" "${REGISTRIES_CONFIG}"

if [[ -e "${POLICY}" ]]; then
  if ! grep -q '"ghcr.io/echocat/bluecat"' "${POLICY}" || ! grep -q '"sigstoreSigned"' "${POLICY}"; then
    echo "ERROR: ${POLICY} already exists and does not contain a bluecat sigstoreSigned policy." >&2
    echo "       Add a ghcr.io/echocat/bluecat sigstoreSigned policy or move the existing file aside." >&2
    exit 1
  fi
else
  echo "=== Installing containers policy for bluecat signature verification..."
  install -D -m 0644 "${TMP_DIR}/policy.json" "${POLICY}"
fi

systemctl stop rpm-ostreed.service >/dev/null 2>&1 || true

echo "=== rpm-ostree rebase..."
echo "=== Using ostree-image-signed:registry:${IMAGE_REF}"
rpm-ostree rebase "ostree-image-signed:registry:${IMAGE_REF}"

echo "=== Enabling local initramfs regeneration for early boot branding..."
if rpm-ostree initramfs --enable; then
  echo "=== Initramfs regeneration enabled."
else
  echo "=== WARNING: failed to enable initramfs regeneration; rebase remains staged." >&2
  echo "=== WARNING: if early boot branding stays unchanged after reboot, run:" >&2
  echo "=== WARNING:   sudo rpm-ostree initramfs --enable" >&2
fi

echo
echo "=== Rebase staged. Reboot with: sudo systemctl reboot"

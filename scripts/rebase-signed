#!/usr/bin/env bash
set -euo pipefail

if [[ "${EUID}" -ne 0 ]]; then
  echo "ERROR: run this script as root, for example via: curl ... | sudo bash" >&2
  exit 1
fi

RAW_BASE="${BLUECAT_RAW_BASE:-https://raw.githubusercontent.com/echocat/bluecat/main}"
IMAGE_REF="${BLUECAT_IMAGE_REF:-ghcr.io/echocat/bluecat:44}"
TMP_DIR="$(mktemp -d)"
trap 'rm -rf "${TMP_DIR}"' EXIT

curl -fsSL "${RAW_BASE}/certs/cosign.pub" -o "${TMP_DIR}/bluecat-cosign.pub"
curl -fsSL "${RAW_BASE}/system_files/etc/containers/policy.json" -o "${TMP_DIR}/policy.json"

install -D -m 0644 "${TMP_DIR}/bluecat-cosign.pub" \
  /etc/pki/containers/bluecat-cosign.pub

if [[ -e /etc/containers/policy.json && ! -e /etc/containers/policy.json.bluecat-backup ]]; then
  cp -a /etc/containers/policy.json /etc/containers/policy.json.bluecat-backup
fi
install -D -m 0644 "${TMP_DIR}/policy.json" /etc/containers/policy.json

rpm-ostree rebase "ostree-image-signed:registry:${IMAGE_REF}"

echo
echo "Rebase staged. Reboot with: sudo systemctl reboot"
